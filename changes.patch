+        cur = conn.cursor()
+        cur.execute(
+            "SELECT * FROM licenses WHERE channel_id = %s AND revoked = 0 LIMIT 1",
+            (channel_id,),
+        )
+        row = cur.fetchone()
+        return dict(row) if row else None
